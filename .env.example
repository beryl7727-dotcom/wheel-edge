# Wheel Edge — Environment Variables
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and is loaded with higher priority than .env by Create React App.

# ── Supabase (source of truth) ────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
# REACT_APP_SUPABASE_URL must be the bare project URL — do NOT append /rest/v1/,
# the Supabase client appends that path internally.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Tiger API (optional live market data) ────────────────────────────────────
# Credentials are loaded from tiger_openapi_config.properties (never commit this file).
# See tiger_openapi_config.properties.example for the expected format.
